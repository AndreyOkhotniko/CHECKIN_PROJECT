# Настройки проекта
PROJECT_NAME="My FastAPI Project"
VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# База данных PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fastapi_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL для подключения (формируется автоматически в коде)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_db
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastapi_db

# Админ-панель БД
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin