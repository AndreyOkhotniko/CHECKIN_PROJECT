# Скопируйте этот файл в .env и заполните реальными значениями:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# Файл .env в git НЕ коммитится (см. .gitignore).

# Настройки проекта
PROJECT_NAME="Checkin"
VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=True

# КЛЮЧ ПОДПИСИ JWT — обязательно сгенерируйте свой!
# Пример генерации: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-real-random-key

# База данных PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fastapi_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Админ-панель PgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=change-me
